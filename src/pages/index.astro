---
/**
 * src/pages/index.astro
 */
import SiteLayout from "../layouts/SiteLayout.astro";

const title = "Ekonomirum | Furnished accommodation in Karlstad & Hammarö";
const description =
  "Furnished apartments and houses in Karlstad and Hammarö. Choose your language to view details and contact information.";
---

<SiteLayout lang="root" title={title} description={description}>
  <h1>Ekonomirum i Karlstad</h1>

  <p>
    Furnished accommodation in Karlstad and Hammarö, Sweden.
    Please choose your language to view available housing information and contact details.
  </p>

  <nav aria-label="Language selection">
    <ul>
      <li><a href="/sv/">🇸🇪 Svenska</a></li>
      <li><a href="/en/">🇬🇧 English</a></li>
      <li><a href="/pl/">🇵🇱 Polski</a></li>
      <li><a href="/lt/">🇱🇹 Lietuvių</a></li>
      <li><a href="/lv/">🇱🇻 Latviešu</a></li>
      <li><a href="/et/">🇪🇪 Eesti</a></li>
    </ul>
  </nav>

  <p class="note">
    Tip: Bookmark your preferred language page (for example <code>/en/</code> or <code>/sv/</code>).
  </p>

  <style>
    /* Lokal styling (matchar din gamla "card"-känsla) */
    .wrap h1 {
      margin: 0 0 10px;
      font-size: 1.9rem;
    }

    .wrap nav ul {
      list-style: none;
      padding: 0;
      margin: 18px 0 0;
      display: grid;
      gap: 10px;
    }

    .wrap nav a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 14px;
      text-decoration: none;
      background: rgba(255, 255, 255, 0.55);
      color: #020617;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
      transition: transform 0.12s ease, box-shadow 0.12s ease;
    }

    .wrap nav a:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
    }

    .note {
      margin-top: 18px;
      font-size: 0.9rem;
      color: #475569;
    }
  </style>
</SiteLayout>