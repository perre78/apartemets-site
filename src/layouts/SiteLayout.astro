---
/**
 * src/layouts/SiteLayout.astro
 * Ändring: stöd för root "/" som språk-hubb med egen canonical + x-default,
 * samt att loggan/brand-länken kan peka till "/" när man är på root.
 */
const {
  lang = "sv",
  title = "Ekonomirum i Karlstad",
  description = "Default description",
} = Astro.props;

const base = import.meta.env.BASE_URL;

// Språk-startsidor
const svUrl = `${base}sv/`;
const enUrl = `${base}en/`;
const plUrl = `${base}pl/`;
const ltUrl = `${base}lt/`;
const lvUrl = `${base}lv/`;
const etUrl = `${base}et/`;

// Root (ingångssida)
const rootUrl = `${base}`;

// Bygg absoluta URL:er (kräver att `site` är satt i astro.config.mjs)
const abs = (p: string) => new URL(p, Astro.site).toString();

// Root-läge: använd lang="root" på ingångssidan
const isRoot = lang === "root";

// Canonical
const canonical = isRoot
  ? abs(rootUrl)
  : lang === "sv"
    ? abs(svUrl)
    : lang === "en"
      ? abs(enUrl)
      : lang === "pl"
        ? abs(plUrl)
        : lang === "lt"
          ? abs(ltUrl)
          : lang === "lv"
            ? abs(lvUrl)
            : lang === "et"
              ? abs(etUrl)
              : abs(svUrl);

// x-default: root när man är på root, annars EN (som du hade)
const xDefault = isRoot ? abs(rootUrl) : abs(enUrl);

// Brand-länk: root om root, annars respektive språk-start
const brandHref = isRoot
  ? rootUrl
  : lang === "sv"
    ? svUrl
    : lang === "pl"
      ? plUrl
      : lang === "lt"
        ? ltUrl
        : lang === "lv"
          ? lvUrl
          : lang === "et"
            ? etUrl
            : enUrl;

// html lang-attribut: på root sätter vi "en" (eller "sv" om du hellre vill)
const htmlLang = isRoot ? "en" : lang;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:site_name" content="Ekonomirum i Karlstad" />
    <meta name="application-name" content="Ekonomirum i Karlstad" />
    <meta name="apple-mobile-web-app-title" content="Ekonomirum i Karlstad" />
    <title>{title}</title>

    <!-- Canonical + hreflang -->
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="sv" href={abs(svUrl)} />
    <link rel="alternate" hreflang="en" href={abs(enUrl)} />
    <link rel="alternate" hreflang="pl" href={abs(plUrl)} />
    <link rel="alternate" hreflang="lt" href={abs(ltUrl)} />
    <link rel="alternate" hreflang="lv" href={abs(lvUrl)} />
    <link rel="alternate" hreflang="et" href={abs(etUrl)} />
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <style is:global>
      :root {
        --text: rgba(255, 255, 255, 0.92);
        --muted: rgba(255, 255, 255, 0.72);
        --border: rgba(255, 255, 255, 0.14);
        --shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
        --radius: 18px;
        --maxw: 880px; /* Maxbredd för innehåll */

        /* ENDA stället som styr bildstorlek (generellt innehåll) */
        --img-max: 320px;

        /* Kontaktkort */
        --contact-photo: 100px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family:
          system-ui,
          -apple-system,
          Segoe UI,
          Roboto,
          Arial;
        color: var(--text);
        line-height: 1.55;
      }

      a {
        color: inherit;
      }

      /* ===== HEADER ===== */
      .header {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(10px);
        background: rgba(11, 18, 32, 0.65);
        border-bottom: 1px solid var(--border);
      }
      .header-inner {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      
      .brand {
        display: flex;
        align-items: center;
      }
      
      .brand-text {
        font-weight: 600;
        font-size: 1.05rem;
        letter-spacing: 0.3px;
      }
      
      .lang {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .pill {
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.06);
        text-decoration: none;
        font-size: 0.95rem;
      }

      .pill[aria-current="page"] {
        background: rgba(255, 255, 255, 0.25);
        pointer-events: none;
      }

      /* ===== CONTENT ===== */
      .wrap {
        max-width: var(--maxw);
        margin: 32px auto;
        padding: 28px 22px;
        background: rgba(255, 255, 255, 0.92);
        color: #0f172a;
        border-radius: 22px;
        box-shadow: var(--shadow);
      }

      h1,
      h2 {
        color: #020617;
      }
      p,
      li {
        color: #334155;
      }

      .section {
        margin-top: 18px;
        padding: 18px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: rgba(218, 213, 213, 0.6); /* färg på mitten-sektionerna */
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.18);
      }

      /* ===== GENERELLA BILDER I INNEHÅLL ===== */
      main.wrap img {
        width: min(100%, var(--img-max));
        height: auto;
        display: block;
        margin: 1.5rem auto;
        border-radius: 12px;
      }

      /* ===== BILDRAD (två bilder bredvid varandra) ===== */
      .image-row {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
        align-items: stretch;
      }

      .image-row img {
        width: 100%;
        max-width: 50%;
        height: auto;
        margin: 0; /* tar bort auto-centering från globala img */
      }

      /* Mobil: stapla */
      @media (max-width: 640px) {
        .image-row {
          flex-direction: column;
        }
        .image-row img {
          max-width: 100%;
        }
      }

      /* Skugga på "vanliga" bilder men inte specialfall */
      main.wrap img:not(.no-global):not(.image-row img) {
        display: block;
        width: var(--img-max);
        max-width: 100%;
        height: auto;
        margin: 1.5rem auto;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
      }

      /* ===== KONTAKTKORT ===== */
      .contact-card {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 20px;
        align-items: start;
        max-width: 560px;
        margin-top: 18px;
      }

      .contact-photo {
        width: var(--contact-photo) !important;
        max-width: var(--contact-photo) !important;
        height: auto !important;
        margin: 0 !important;
        display: block;
        border-radius: 10px;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.18);
      }

      .contact-info {
        line-height: 1.55;
      }

      .contact-note {
        margin-top: 8px;
        font-size: 0.95em;
        opacity: 0.85;
      }

      @media (max-width: 640px) {
        .contact-card {
          grid-template-columns: 1fr;
          text-align: center;
        }
        .contact-photo {
          margin: 0 auto;
        }
      }

      footer {
        max-width: var(--maxw);
        margin: 24px auto;
        padding: 0 16px 22px;
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.95rem;
      }
    </style>
  </head>

  <body
    style={`
      background:
        linear-gradient(rgba(11,18,32,.78), rgba(11,18,32,.78)),
        url('${base}img/Areal_photo_of_Karlstad.jpg');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    `}
  >
    <header class="header">
      <div class="header-inner">
        <div class="brand">
          <span class="brand-text">Ekonomirum i Karlstad</span>
        </div>

        <nav class="lang">
          <a class="pill" href={svUrl} aria-current={lang === "sv" ? "page" : undefined}>🇸🇪 SV</a>
          <a class="pill" href={enUrl} aria-current={lang === "en" ? "page" : undefined}>🇬🇧 EN</a>
          <a class="pill" href={plUrl} aria-current={lang === "pl" ? "page" : undefined}>🇵🇱 PL</a>
          <a class="pill" href={ltUrl} aria-current={lang === "lt" ? "page" : undefined}>🇱🇹 LT</a>
          <a class="pill" href={lvUrl} aria-current={lang === "lv" ? "page" : undefined}>🇱🇻 LV</a>
          <a class="pill" href={etUrl} aria-current={lang === "et" ? "page" : undefined}>🇪🇪 ET</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer>© 2025 – Ekonomirum i Karlstad</footer>
  </body>
</html>